{
  "name": "kloetzchenpackagetrynrone",
  "containerUser": "ros2",
  "initializeCommand": [
    "docker",
    "build",
    "--file=aica-package.toml",
    "--target=development",
    "--build-arg=config.signing.enabled=false",
    "--tag=aica-technology/kloetzchenpackagetrynrone:development",
    "."
  ],
  "image": "aica-technology/kloetzchenpackagetrynrone:development",
  "postStartCommand": "rm -r /home/ros2/ws/src/kloetzchenpackagetrynrone && ln -s ${containerWorkspaceFolder}/source/kloetzchenpackagetrynrone /home/ros2/ws/src/kloetzchenpackagetrynrone",
  "postCreateCommand": "/usr/local/bin/generate_compile_commands -p kloetzchenpackagetrynrone -t 60 -o ${containerWorkspaceFolder} --cmake-args BUILD_TESTING=ON",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "llvm-vs-code-extensions.vscode-clangd",
        "xaver.clang-format",
        "charliermarsh.ruff"
      ]
    }
  }
}